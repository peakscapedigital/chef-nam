---
/**
 * Sitemap — human-readable directory page (the XML sitemap for crawlers is
 * sitemap-index.xml, generated by @astrojs/sitemap). Shares its page list
 * with /llms.txt via ../utils/site-index so the two never drift.
 */
import Layout from '../layouts/Layout.astro';
import { STATIC_PAGES, getDynamicSections } from '../utils/site-index';

const sections = await getDynamicSections();
const groups = [{ heading: 'Pages', items: STATIC_PAGES }, ...sections];
---

<Layout
  title="Sitemap | Chef Nam Catering"
  description="A directory of every page on the Chef Nam Catering website."
>
  <section class="bg-brand-cream/30 py-16">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h1 class="text-4xl md:text-5xl font-serif font-bold text-brand-indigo mb-4">Sitemap</h1>
      <p class="text-lg text-brand-indigo/70 max-w-2xl mx-auto">Everything on the site, in one place.</p>
    </div>
  </section>

  <section class="py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid gap-x-12 gap-y-10 sm:grid-cols-2 lg:grid-cols-3">
        {groups.map((group) => (
          <div>
            <h2 class="text-2xl font-serif font-bold text-brand-indigo pb-2 mb-4 border-b border-brand-amber/40">
              {group.heading}
            </h2>
            <ul class="space-y-4">
              {group.items.map((item) => (
                <li>
                  <a href={item.path} class="font-semibold text-brand-indigo hover:text-brand-amber transition-colors">
                    {item.title}
                  </a>
                  {item.desc && <p class="text-sm text-brand-indigo/60 mt-0.5 leading-snug">{item.desc}</p>}
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </div>
  </section>
</Layout>
