---
import '../styles/global.css';
import { attributionCaptureScript } from '@peakscape/site-kit/attribution';
import { consentBootstrapScript, EEA_UK_REGIONS, ALL_DENIED } from '@peakscape/site-kit/consent';

export interface Props {
  title: string;
  description?: string;
  canonical?: string;
  noindex?: boolean;
}

const {
  title,
  description = 'Professional catering services in Ann Arbor, Michigan. Thai fusion cuisine for weddings, corporate events, and special occasions.',
  canonical,
  noindex = false
} = Astro.props;

const canonicalUrl = canonical || `https://chefnamcatering.com${Astro.url.pathname}`;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="description" content={description} />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  {noindex && <meta name="robots" content="noindex, nofollow" />}

  <!-- Favicons -->
  <link rel="icon" href="/favicon.png" />
  <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
  <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
  <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
  <link rel="manifest" href="/site.webmanifest" />

  <meta name="generator" content={Astro.generator} />
  <link rel="canonical" href={canonicalUrl} />

  <!-- Preconnect -->
  <link rel="preconnect" href="https://cdn.sanity.io" />
  <link rel="preconnect" href="https://www.googletagmanager.com" />

  <!-- Open Graph -->
  <meta property="og:type" content="website" />
  <meta property="og:url" content={canonicalUrl} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content="https://chefnamcatering.com/images/logo/chef-nam-logo-square.png" />
  <meta property="og:site_name" content="Chef Nam Catering" />

  <!-- Twitter -->
  <meta property="twitter:card" content="summary_large_image" />
  <meta property="twitter:title" content={title} />
  <meta property="twitter:description" content={description} />

  <title>{title}</title>

  <!-- Additional head content -->
  <slot name="head" />

  <!-- Consent Mode v2 defaults (must run before GTM) — @peakscape/site-kit/consent -->
  <script is:inline set:html={consentBootstrapScript({ regionDefaults: [{ regions: EEA_UK_REGIONS, defaults: ALL_DENIED }] })} />

  <!-- First-party attribution capture (@peakscape/site-kit, SYS-007) -->
  <script is:inline set:html={attributionCaptureScript({ domain: 'chefnamcatering.com' })} />

  <!-- Google Tag Manager -->
  <script>
  // Window augmented with GTM's dataLayer (untyped third-party global).
  interface DataLayerWindow extends Window { dataLayer?: Record<string, unknown>[]; }
  const dlw = window as DataLayerWindow;
  dlw.dataLayer = dlw.dataLayer || [];
  let gtmLoaded = false;
  function loadGTM() {
    if (gtmLoaded) return;
    gtmLoaded = true;
    // Typed equivalent of the standard GTM snippet (id GTM-WCMPN842).
    dlw.dataLayer = dlw.dataLayer || [];
    dlw.dataLayer.push({ 'gtm.start': new Date().getTime(), event: 'gtm.js' });
    const f = document.getElementsByTagName('script')[0];
    const j = document.createElement('script');
    j.async = true;
    j.src = 'https://www.googletagmanager.com/gtm.js?id=GTM-WCMPN842';
    f?.parentNode?.insertBefore(j, f);
  }
  ['mousedown', 'touchstart', 'keydown', 'scroll'].forEach(event =>
    document.addEventListener(event, loadGTM, {once: true, passive: true})
  );
  setTimeout(loadGTM, 3000);
  </script>
</head>
<body class="bg-brand-white text-brand-indigo">
  <!-- GTM noscript -->
  <noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-WCMPN842"
  height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>

  <!-- No cookie banner — US-first posture (matches Sugar House): Consent Mode v2
       region defaults handle compliance (US/RoW granted, EEA/UK/CH denied). -->

  <slot />

  <!-- Phone Click Tracking -->
  <script>
    import { trackPhoneClick } from '../lib/tracking';
    document.addEventListener('DOMContentLoaded', () => {
      document.querySelectorAll('a[href^="tel:"]').forEach(link => {
        link.addEventListener('click', () => {
          trackPhoneClick({
            phone_number: link.getAttribute('href')?.replace('tel:', '') ?? '',
            event_label: 'Phone Click - Landing Page',
          });
        });
      });
    });
  </script>
</body>
</html>
